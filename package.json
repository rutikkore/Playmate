{
  "name": "playmate-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w playmate-frontend",
    "dev:backend": "npm run dev -w playmate-backend",
    "dev": "npm run dev -w playmate-backend & npm run dev -w playmate-frontend",
    "build:frontend": "npm run build -w playmate-frontend",
    "build:backend": "npm run build -w playmate-backend",
    "build": "npm run build -w playmate-backend && npm run build -w playmate-frontend",
    "lint:frontend": "npm run lint -w playmate-frontend",
    "lint": "npm run lint -w playmate-frontend"
  }
}
