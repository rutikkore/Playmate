datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  PROVIDER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SlotStatus {
  AVAILABLE
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CancelledBy {
  PLAYER
  PROVIDER
  SYSTEM
}

model User {
  id            String   @id @default(cuid())
  firebaseUid   String   @unique
  email         String   @unique
  name          String?
  photoUrl      String?
  role          Role     @default(PLAYER)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  providerProfile ProviderProfile?
  favourites      Favourite[]
  bookings        Booking[]
  hostedMatches   Match[]           @relation("HostedMatches")
  matchParticipations MatchParticipant[]
}

model ProviderProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  contactPhone       String?
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relationships
  turfs Turf[]
}

model Sport {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  turfs     TurfSport[]
  matches   Match[]
}

model Turf {
  id           String   @id @default(cuid())
  name         String
  description  String?
  location     String
  latitude     Float?
  longitude    Float?
  pricePerHour Float
  courts       Int      @default(1)
  images       String[] @default([])
  status       String   @default("active") // active, inactive
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  sports     TurfSport[]
  slots      AvailabilitySlot[]
  favourites Favourite[]
  
  // Placeholders
  bookings   Booking[]
  reviews    Review[]

  @@index([providerId])
  @@index([isDeleted])
}

model TurfSport {
  turfId  String
  sportId String
  turf    Turf   @relation(fields: [turfId], references: [id], onDelete: Cascade)
  sport   Sport  @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([turfId, sportId])
}

model AvailabilitySlot {
  id        String     @id @default(cuid())
  turfId    String
  turf      Turf       @relation(fields: [turfId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String     // e.g. "06:00 AM" or "06:00"
  endTime   String     // e.g. "07:00 AM" or "07:00"
  status    SlotStatus @default(AVAILABLE)
  price     Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relationships
  booking   Booking?

  @@unique([turfId, date, startTime])
  @@index([turfId, date])
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  turfId    String
  turf      Turf     @relation(fields: [turfId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, turfId])
  @@index([userId])
}

// Placeholder models for Milestone 3+ (minimal)
model Booking {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  turfId      String
  turf        Turf             @relation(fields: [turfId], references: [id], onDelete: Restrict)
  slotId      String           @unique
  slot        AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Restrict)
  status      BookingStatus    @default(CONFIRMED)
  totalPrice  Decimal
  cancelledAt DateTime?
  cancelledBy CancelledBy?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relationships
  match       Match?

  @@index([userId])
  @@index([turfId])
  @@index([status])
}

model Match {
  id               String             @id @default(cuid())
  bookingId        String             @unique
  booking          Booking            @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  hostId           String
  host             User               @relation("HostedMatches", fields: [hostId], references: [id], onDelete: Restrict)
  sportId          String
  sport            Sport              @relation(fields: [sportId], references: [id], onDelete: Restrict)
  description      String?            // Optional notes/description
  status           MatchStatus        @default(OPEN)
  skillLevel       SkillLevel         @default(MIXED)
  maxPlayers       Int                // Max players capacity (e.g. 10 for 5v5)
  participantCount Int                @default(1) // Cache the count, initialized to 1 (the host)
  visibility       MatchVisibility    @default(PUBLIC)
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relationships
  participants     MatchParticipant[]

  // Indexes
  @@index([hostId])
  @@index([status])
  @@index([sportId])
  @@index([visibility])
  @@index([status, visibility])
}

model MatchParticipant {
  id        String          @id @default(cuid())
  matchId   String
  match     Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ParticipantRole @default(PLAYER)
  joinedAt  DateTime        @default(now())

  // Unique Constraint: One user can join a match only once
  @@unique([matchId, userId])
  @@index([matchId])
}

enum MatchStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  MIXED
}

enum ParticipantRole {
  HOST
  PLAYER
}

enum MatchVisibility {
  PUBLIC
  PRIVATE
}

model Review {
  id        String   @id @default(cuid())
  turfId    String
  turf      Turf     @relation(fields: [turfId], references: [id])
  rating    Int
  createdAt DateTime @default(now())
}
